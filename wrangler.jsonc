{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cf-ai-system-sentinel",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-29",
	"migrations": [
		{
			"tag": "v1",
			"new_classes": ["SentinelState"],
		},
	],
	"assets": {
		"directory": "./public",
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "SENTINEL_STATE",
				"class_name": "SentinelState",
			},
		],
	},
	"ai": {
		"binding": "AI",
		"remote": true,
	},
	"observability": {
		"enabled": true,
	},
}
